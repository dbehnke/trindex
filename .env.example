# Trindex Environment Configuration
# Copy this file to .env and customize for your setup

# =============================================================================
# Trindex Client Configuration (for MCP proxy mode)
# =============================================================================
# URL of the Trindex server for MCP client to connect to
# Use this when running 'trindex mcp' as a thin client proxy
# Default: http://localhost:9636
# TRINDEX_URL=http://localhost:9636

# API key for authenticating with the Trindex server (optional but recommended)
# Must match TRINDEX_API_KEY set on the server
# TRINDEX_API_KEY=your-secret-key

# =============================================================================
# Database Configuration (Server-side only)
# =============================================================================
# Postgres connection string
# Default: local Postgres via Docker Compose
DATABASE_URL=postgres://trindex:trindex@localhost:5432/trindex?sslmode=disable

# =============================================================================
# Embedding Configuration (Server-side only)
# =============================================================================
# OpenAI-compatible embedding endpoint
# Examples:
#   - Ollama: http://host.docker.internal:11434/v1 (when Trindex is in Docker)
#   - Ollama: http://localhost:11434/v1 (when Trindex is native)
#   - LM Studio: http://localhost:1234/v1
#   - OpenAI: https://api.openai.com/v1
EMBED_BASE_URL=http://localhost:11434/v1

# Embedding model to use
# Examples:
#   - Ollama: nomic-embed-text, mxbai-embed-large
#   - OpenAI: text-embedding-3-small, text-embedding-3-large
EMBED_MODEL=nomic-embed-text

# API key for embedding endpoint
# For Ollama, this can be any non-empty string (e.g., "ollama")
# For OpenAI, use your actual API key
EMBED_API_KEY=ollama

# Embedding dimensions (must match your model)
#   - nomic-embed-text: 768
#   - text-embedding-3-small: 1536
#   - text-embedding-3-large: 3072
EMBED_DIMENSIONS=768

# =============================================================================
# HTTP Server Configuration (Server-side only)
# =============================================================================
# HTTP server host and port for web UI and REST API
HTTP_HOST=0.0.0.0
HTTP_PORT=9636

# API key for HTTP endpoints (optional but recommended for production)
# Clients must provide this key via X-API-Key header
# Leave empty to disable authentication
TRINDEX_API_KEY=

# =============================================================================
# Hybrid Search Weights
# =============================================================================
# Vector search weight (0.0 - 1.0)
# Default: 0.7
HYBRID_VECTOR_WEIGHT=0.7

# Full-text search weight (0.0 - 1.0)
# Default: 0.3
HYBRID_FTS_WEIGHT=0.3

# =============================================================================
# Connection Pooling (Advanced)
# =============================================================================
# Maximum number of open connections to the database
DB_MAX_CONNS=100

# Minimum number of open connections to maintain
DB_MIN_CONNS=10

# Maximum lifetime of a connection in minutes
DB_MAX_CONN_LIFETIME_MINUTES=60

# Maximum idle time of a connection in minutes
DB_MAX_CONN_IDLE_TIME_MINUTES=30

# =============================================================================
# Embedding Client Retry (Advanced)
# =============================================================================
# Maximum number of retry attempts for embedding requests
EMBED_MAX_RETRIES=3

# Delay between retries in milliseconds
EMBED_RETRY_DELAY_MS=1000

# Request timeout for embedding API calls in seconds
EMBED_REQUEST_TIMEOUT_SEC=30
