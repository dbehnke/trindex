# Trindex Environment Configuration
# Copy this file to .env and customize for your setup

# =============================================================================
# Database Configuration
# =============================================================================
# Postgres connection string
# Default: local Postgres via Docker Compose
DATABASE_URL=postgres://trindex:trindex@localhost:5432/trindex?sslmode=disable

# =============================================================================
# Embedding Configuration
# =============================================================================
# OpenAI-compatible embedding endpoint
# Examples:
#   - Ollama: http://localhost:11434/v1
#   - LM Studio: http://localhost:1234/v1
#   - OpenAI: https://api.openai.com/v1
EMBED_BASE_URL=http://localhost:11434/v1

# Embedding model to use
# Examples:
#   - Ollama: nomic-embed-text, mxbai-embed-large
#   - OpenAI: text-embedding-3-small, text-embedding-3-large
EMBED_MODEL=nomic-embed-text

# API key for embedding endpoint
# For Ollama, this can be any non-empty string (e.g., "ollama")
# For OpenAI, use your actual API key
EMBED_API_KEY=ollama

# Embedding dimensions (must match your model)
#   - nomic-embed-text: 768
#   - text-embedding-3-small: 1536
#   - text-embedding-3-large: 3072
EMBED_DIMENSIONS=768

# =============================================================================
# MCP Transport Configuration
# =============================================================================
# Transport mode: stdio (Phase 1) or http (Phase 2)
TRANSPORT=stdio

# =============================================================================
# HNSW Index Tuning (Advanced)
# =============================================================================
# M: Number of bi-directional links for each node
# Higher = better recall, more memory
HNSW_M=16

# ef_construction: Size of dynamic candidate list during construction
# Higher = better index quality, slower construction
HNSW_EF_CONSTRUCTION=64

# ef_search: Size of dynamic candidate list during search
# Higher = better recall, slower search
HNSW_EF_SEARCH=40

# =============================================================================
# Recall Defaults
# =============================================================================
# Default namespace for memories
DEFAULT_NAMESPACE=default

# Default number of results to return
DEFAULT_TOP_K=10

# Default minimum similarity threshold (0.0 - 1.0)
DEFAULT_SIMILARITY_THRESHOLD=0.7

# =============================================================================
# Web Server Configuration (Phase 2)
# =============================================================================
# HTTP server host and port for web UI and REST API
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# API key for HTTP endpoints (optional but recommended for production)
# Leave empty to disable authentication
TRINDEX_API_KEY=
