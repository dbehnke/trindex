#!/bin/sh
# Pre-commit hook for Trindex
# Requires golangci-lint to be installed
# Install with: ./scripts/install-hooks.sh

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "Running pre-commit checks..."

# Check if there are any Go files or go.mod
if [ ! -f "go.mod" ] && [ -z "$(find . -name '*.go' -not -path './.git/*' 2>/dev/null | head -1)" ]; then
    echo "${YELLOW}No Go files or go.mod found - skipping lint check${NC}"
    exit 0
fi

# Check if golangci-lint is installed
if ! command -v golangci-lint >/dev/null 2>&1; then
    echo "${YELLOW}Warning: golangci-lint not found in PATH${NC}"
    echo "Install it from: https://golangci-lint.run/usage/install/"
    echo ""
    echo "Quick install options:"
    echo "  # macOS with Homebrew:"
    echo "  brew install golangci-lint"
    echo ""
    echo "  # Linux/other with curl:"
    echo "  curl -sSfL https://raw.githubusercontent.com/golangci-lint/run/master/install.sh | sh -s -- -b $(go env GOPATH)/bin"
    echo ""
    echo "Skipping lint check. Commit will proceed."
    exit 0
fi

# Run golangci-lint
echo "Running golangci-lint..."
if ! golangci-lint run ./...; then
    echo ""
    echo "${RED}✗ golangci-lint failed${NC}"
    echo ""
    echo "Please fix the linting errors before committing."
    echo "You can run 'golangci-lint run --fix' to auto-fix some issues."
    exit 1
fi

echo ""
echo "${GREEN}✓ All checks passed${NC}"
exit 0
